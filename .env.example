# Database
DATABASE_URL=sqlite:./data/ai-hub.db

# Encryption (Required - Generate with: openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32

# Initial admin account (ADMIN_PASSWORD is required only when creating the first admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourSecurePassword123!@#

# Logging
RUST_LOG=warn
TZ=Asia/Shanghai

# Server
PORT=8080

# CORS (comma-separated origins; DO NOT use * in production)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Session expiration
SESSION_TTL_HOURS=24

# Set true behind HTTPS in production so browsers only send auth cookies over TLS
COOKIE_SECURE=false

# Request body limit for JSON/CSV uploads (1-50 MB, default 5)
REQUEST_BODY_LIMIT_MB=5
