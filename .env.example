# Database
DATABASE_URL=sqlite:./data/ai-hub.db

# Encryption (Required - Generate with: openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32

# Initial admin account (ADMIN_PASSWORD is required only when creating the first admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-at-least-8-chars

# Logging
RUST_LOG=info
TZ=Asia/Shanghai

# CORS (comma-separated origins; use * only for local testing)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Session expiration
SESSION_TTL_HOURS=24



