# Database
DATABASE_URL=sqlite:./data/ai-hub.db

# Encryption (Required - Generate with: openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here

# Admin Account (Optional - Defaults shown)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Logging
RUST_LOG=info
TZ=Asia/Shanghai
